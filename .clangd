# ------------------------------------------------------------
#  Block 1: Common Base Settings (Applies to all files)
# ------------------------------------------------------------
CompileFlags:
  Add:
    - "--target=riscv32-unknown-elf"
    - "-x"
    - "c"
    - "-std=gnu99"

    # Suppress false-positive warnings for embedded C
    - "-Wno-implicit-function-declaration"
    - "-Wno-int-conversion"
    - "-Wno-incompatible-pointer-types"
    - "-Wno-attributes"
    - "-Wno-unknown-attributes"
    - "-Wno-ignored-attributes"

  Remove:
    - "-march=*"
    - "-mabi=*"
    - "-msmall-data-limit=*"
    - "-msave-restore"
    - "-fsingle-precision-constant"
    - "-fmessage-length=*"
    - "-fno-common"
    - "-nostartfiles"
    - "-Xlinker"
    - "--gc-sections"
    - "--specs=*"
    - "-lm"

Diagnostics:
  UnusedIncludes: None
  Suppress:
    - "pp_including_mainfile_in_preamble"
    - "drv_unknown_argument"
    - "ignored_attributes"
    - "unknown_attribute"
  ClangTidy:
    Remove:
      - "modernize-*"
      - "cppcoreguidelines-*"
      - "readability-*"
      - "performance-*"
      - "bugprone-reserved-identifier"
      - "cert-dcl37-c"
      - "cert-dcl51-cpp"

Index:
  Background: Build

---
