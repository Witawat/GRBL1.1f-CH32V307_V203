# ============================================================
#  .clangd - auto-generated by make_clangd.bat
#  Project  : GRBL CH32V307 (6-Axis CNC Controller)
#  MCU      : CH32V307 (rv32imafc, 144MHz, FPU)
#  Toolchain: RISC-V Embedded GCC (riscv-none-embed-gcc)
#  Re-run make_clangd.bat to update when project structure changes
# ============================================================
#
#  THIS FILE IS AUTO-GENERATED.
#  Run: .\scripts\make_clangd.bat
#  to regenerate with correct include paths.
# ============================================================

CompileFlags:
  Compiler: "C:/MounRiver/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC/bin/riscv-none-embed-gcc.exe"

  Add:
    # Force RISC-V 32-bit target
    - "--target=riscv32-unknown-elf"

    # Force C language for .h files
    - "-x"
    - "c"

    # C Standard
    - "-std=gnu99"

    # Project include paths
    - "-I"
    - "grbl"
    - "-I"
    - "mcu/CH32V307"
    - "-I"
    - "mcu/CH32V307/sdk/Core"
    - "-I"
    - "mcu/CH32V307/sdk/Debug"
    - "-I"
    - "mcu/CH32V307/sdk/Peripheral/inc"

    # Preprocessor Defines
    - "-D_DEBUG"
    - "-DCH32V307"
    - "-DCH32V30x"
    - "-DABC_AXIS_EXAMPLE"
    - "-DAB_AXIS"

    # Suppress false-positive warnings for embedded C
    - "-Wno-implicit-function-declaration"
    - "-Wno-int-conversion"
    - "-Wno-incompatible-pointer-types"
    - "-Wno-attributes"

  Remove:
    # Strip RISC-V / WCH-specific flags that clangd doesn't understand
    - "-march=rv32imafc"
    - "-march=rv32imac"
    - "-mabi=ilp32f"
    - "-mabi=ilp32"
    - "-msmall-data-limit=*"
    - "-msave-restore"
    - "-fsingle-precision-constant"
    - "-fmessage-length=*"
    - "-fno-common"
    - "-nostartfiles"
    - "-Xlinker"
    - "--gc-sections"
    - "--specs=*"
    - "-lm"

Diagnostics:
  UnusedIncludes: None
  Suppress:
    - "pp_including_mainfile_in_preamble"
  ClangTidy:
    Remove:
      - "modernize-*"
      - "cppcoreguidelines-*"
      - "readability-*"
      - "performance-*"
      - "bugprone-reserved-identifier"
      - "cert-dcl37-c"
      - "cert-dcl51-cpp"

Index:
  Background: Build
